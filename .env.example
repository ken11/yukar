# yukar — example environment variables
#
# Copy this file to `.env` and fill in the values for the LLM provider you use.
# `.env` is gitignored; only this `.env.example` template is committed.
#
# IMPORTANT: yukar does NOT auto-load `.env`. It reads credentials from the
# process environment (os.environ / the standard AWS SDK credential chain).
# Make sure these variables are exported in the shell that launches yukar, e.g.:
#
#   set -a; . ./.env; set +a       # bash / zsh: export everything in .env
#   pnpm dev                       # (or: uv run yukar serve)
#
# fish:  export (grep -v '^#' .env | string trim) ; pnpm dev
# Or use a tool such as direnv to load .env automatically.
#
# Which provider is actually used is selected in
# ~/.config/yukar/settings.yaml (llm.provider / embedding.provider), not here.
# See the "Configure credentials" section of README.md for details.

# ---------------------------------------------------------------------------
# AWS Bedrock  (default provider for both LLM and Titan embeddings)
# ---------------------------------------------------------------------------
# yukar uses the standard AWS SDK credential chain. The simplest setup is a
# named profile from `aws configure` plus a region:
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1

# Alternatively, use explicit keys instead of a profile (uncomment):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...            # only for temporary credentials

# ---------------------------------------------------------------------------
# Anthropic API  (set llm.provider: anthropic in settings.yaml to use this)
# ---------------------------------------------------------------------------
# yukar reads the key from the env var named by llm.api_key_env
# (default: ANTHROPIC_API_KEY). The key value is never written to settings.yaml.
# Note: the Anthropic provider currently requires `uv add anthropic` in apps/api.
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------
# Disable Next.js anonymous telemetry for this local-only tool. The dev/build/
# start npm scripts already set this; it is documented here for any direct
# `next` invocations.
NEXT_TELEMETRY_DISABLED=1
