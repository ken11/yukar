{
  "name": "web",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev --hostname 127.0.0.1",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "NEXT_TELEMETRY_DISABLED=1 next start",
    "lint": "biome check .",
    "typecheck": "next typegen && tsc --noEmit",
